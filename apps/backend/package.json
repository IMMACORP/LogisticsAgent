{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:generate",
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "typecheck": "tsc -p tsconfig.json",
    "db:generate": "tsx scripts/prisma-generate.ts",
    "db:engines:download": "tsx scripts/download-prisma-engines-curl.ts",
    "postinstall": "tsx scripts/prisma-generate.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:setup": "prisma db push && npm run db:seed",
    "check:openai": "tsx scripts/verify-openai-key.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "openapi:generate": "tsx scripts/generate-openapi.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@hono/zod-openapi": "1.4.0",
    "@inquiry-agent/shared-types": "*",
    "@openai/agents": "^0.4.0",
    "@prisma/client": "^6.19.0",
    "dotenv": "^16.6.1",
    "hono": "^4.12.8",
    "openai": "^6.39.0",
    "pg": "8.16.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.10.3",
    "prisma": "^6.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "yaml": "^2.8.0"
  }
}
