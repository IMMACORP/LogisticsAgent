{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2024",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@inquiry-agent/shared-types": ["../../packages/shared-types/src"],
      "@inquiry-agent/shared-types/*": ["../../packages/shared-types/src/*"]
    },

    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": ["src"]
}