# Enables legacy TLS renegotiation required by some corporate proxies / older TLS stacks
# when Prisma downloads engine binaries (fixes OpenSSL 3 "unsafe legacy renegotiation disabled").
openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
Options = UnsafeLegacyRenegotiation
