{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "lib": ["DOM", "ES2024"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["packages/shared-types/src/*"],
      "@agents/*": ["packages/agents/src/*"]
    }
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts", "apps/**/*.tsx"]
}
